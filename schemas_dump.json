{
  "ActionEnum": {
    "enum": [
      "login",
      "login_failed",
      "logout",
      "logout_all",
      "token_refresh",
      "password_change",
      "password_reset_request",
      "password_reset_complete",
      "2fa_enabled",
      "2fa_disabled",
      "2fa_backup_used",
      "account_created",
      "account_locked",
      "account_unlocked",
      "email_verified",
      "phone_verified",
      "role_assigned",
      "role_removed",
      "permission_changed",
      "app_created",
      "app_credentials_regenerated",
      "account_deleted",
      "suspicious_activity",
      "session_limit_exceeded",
      "device_limit_exceeded",
      "new_device_detected",
      "agent_action"
    ],
    "type": "string",
    "description": "* `login` - Login\n* `login_failed` - Login Failed\n* `logout` - Logout\n* `logout_all` - Logout All Devices\n* `token_refresh` - Token Refresh\n* `password_change` - Password Changed\n* `password_reset_request` - Password Reset Requested\n* `password_reset_complete` - Password Reset Completed\n* `2fa_enabled` - 2FA Enabled\n* `2fa_disabled` - 2FA Disabled\n* `2fa_backup_used` - 2FA Backup Code Used\n* `account_created` - Account Created\n* `account_locked` - Account Locked\n* `account_unlocked` - Account..."
  },
