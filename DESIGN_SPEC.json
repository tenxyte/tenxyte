{
  "_meta": {
    "version": "1.0.0",
    "description": "Design specification for the Tenxyte API documentation site",
    "principles": ["Simplicité", "Élégance", "Modernité", "Accessibilité", "DRY"]
  },

  "tokens": {
    "color": {
      "brand": {
        "primary":   "#6366f1",
        "primary-hover": "#4f46e5",
        "primary-subtle": "#eef2ff"
      },
      "neutral": {
        "50":  "#f8fafc",
        "100": "#f1f5f9",
        "200": "#e2e8f0",
        "400": "#94a3b8",
        "600": "#475569",
        "800": "#1e293b",
        "900": "#0f172a"
      },
      "semantic": {
        "success": "#10b981",
        "warning": "#f59e0b",
        "error":   "#ef4444",
        "info":    "#3b82f6"
      },
      "method": {
        "GET":    "#10b981",
        "POST":   "#6366f1",
        "PUT":    "#f59e0b",
        "PATCH":  "#f97316",
        "DELETE": "#ef4444"
      },
      "surface": {
        "page":    "#ffffff",
        "raised":  "#f8fafc",
        "overlay": "#f1f5f9"
      },
      "text": {
        "primary":   "#0f172a",
        "secondary": "#475569",
        "muted":     "#94a3b8",
        "inverse":   "#ffffff",
        "link":      "#6366f1"
      },
      "border": {
        "default": "#e2e8f0",
        "subtle":  "#f1f5f9",
        "strong":  "#94a3b8"
      },
      "code": {
        "bg":      "#0f172a",
        "text":    "#e2e8f0",
        "comment": "#64748b",
        "keyword": "#a78bfa",
        "string":  "#34d399",
        "number":  "#fb923c"
      }
    },

    "typography": {
      "font": {
        "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        "mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace"
      },
      "size": {
        "xs":   "0.75rem",
        "sm":   "0.875rem",
        "base": "1rem",
        "lg":   "1.125rem",
        "xl":   "1.25rem",
        "2xl":  "1.5rem",
        "3xl":  "1.875rem",
        "4xl":  "2.25rem"
      },
      "weight": {
        "normal":   "400",
        "medium":   "500",
        "semibold": "600",
        "bold":     "700"
      },
      "leading": {
        "tight":  "1.25",
        "normal": "1.5",
        "relaxed":"1.75"
      }
    },

    "spacing": {
      "1":  "0.25rem",
      "2":  "0.5rem",
      "3":  "0.75rem",
      "4":  "1rem",
      "5":  "1.25rem",
      "6":  "1.5rem",
      "8":  "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem"
    },

    "radius": {
      "sm":   "0.375rem",
      "md":   "0.5rem",
      "lg":   "0.75rem",
      "xl":   "1rem",
      "full": "9999px"
    },

    "shadow": {
      "sm":  "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "md":  "0 4px 6px -1px rgb(0 0 0 / 0.07), 0 2px 4px -2px rgb(0 0 0 / 0.05)",
      "lg":  "0 10px 15px -3px rgb(0 0 0 / 0.07), 0 4px 6px -4px rgb(0 0 0 / 0.05)",
      "xl":  "0 20px 25px -5px rgb(0 0 0 / 0.07), 0 8px 10px -6px rgb(0 0 0 / 0.05)"
    },

    "transition": {
      "fast":   "150ms ease",
      "normal": "250ms ease",
      "slow":   "400ms ease"
    },

    "breakpoint": {
      "sm":  "640px",
      "md":  "768px",
      "lg":  "1024px",
      "xl":  "1280px",
      "2xl": "1536px"
    },

    "layout": {
      "nav-height":     "64px",
      "sidebar-width":  "280px",
      "content-max":    "860px",
      "page-max":       "1440px"
    }
  },

  "components": {
    "nav": {
      "position": "sticky top-0",
      "height": "64px",
      "bg": "surface.page",
      "border-bottom": "border.default",
      "backdrop-blur": true,
      "z-index": 100,
      "items": ["brand-logo", "nav-links", "search", "theme-toggle", "cta-button"]
    },

    "sidebar": {
      "width": "280px",
      "bg": "surface.raised",
      "border-right": "border.default",
      "sticky": true,
      "top": "nav-height",
      "overflow": "auto",
      "sections": "grouped by tag",
      "active-indicator": "left-border brand.primary 3px"
    },

    "hero": {
      "layout": "centered",
      "padding": "spacing.20 spacing.8",
      "title-size": "4xl",
      "title-weight": "bold",
      "subtitle-size": "lg",
      "subtitle-color": "text.secondary",
      "cta-gap": "spacing.4",
      "badge": "version badge top"
    },

    "card": {
      "bg": "surface.page",
      "border": "border.default",
      "radius": "radius.lg",
      "shadow": "shadow.sm",
      "padding": "spacing.6",
      "hover-shadow": "shadow.md",
      "hover-transition": "transition.fast"
    },

    "endpoint-block": {
      "border": "border.default",
      "radius": "radius.lg",
      "overflow": "hidden",
      "margin-bottom": "spacing.4",
      "header": {
        "display": "flex align-items-center gap-3",
        "padding": "spacing.4 spacing.5",
        "bg": "surface.raised",
        "cursor": "pointer",
        "hover-bg": "surface.overlay"
      },
      "body": {
        "padding": "spacing.5 spacing.6",
        "border-top": "border.subtle",
        "collapsible": true
      }
    },

    "method-badge": {
      "font-size": "xs",
      "font-weight": "bold",
      "font-family": "mono",
      "padding": "spacing.1 spacing.2",
      "radius": "radius.sm",
      "min-width": "56px",
      "text-align": "center",
      "text-transform": "uppercase",
      "colors": "from tokens.color.method"
    },

    "code-block": {
      "bg": "code.bg",
      "radius": "radius.lg",
      "overflow": "hidden",
      "header": {
        "display": "flex justify-between align-items-center",
        "padding": "spacing.3 spacing.4",
        "bg": "neutral.900",
        "border-bottom": "1px solid neutral.800",
        "lang-label": {
          "font-size": "xs",
          "color": "text.muted",
          "font-family": "mono"
        },
        "copy-button": {
          "font-size": "xs",
          "color": "text.muted",
          "hover-color": "text.inverse",
          "transition": "transition.fast"
        }
      },
      "pre": {
        "padding": "spacing.5",
        "overflow-x": "auto",
        "font-family": "mono",
        "font-size": "sm",
        "line-height": "relaxed",
        "color": "code.text"
      }
    },

    "tab-group": {
      "tabs": {
        "display": "flex",
        "border-bottom": "border.default",
        "gap": "spacing.1",
        "padding-bottom": "0"
      },
      "tab-button": {
        "padding": "spacing.2 spacing.4",
        "font-size": "sm",
        "font-weight": "medium",
        "color": "text.secondary",
        "border-bottom": "2px solid transparent",
        "active-color": "brand.primary",
        "active-border": "brand.primary",
        "hover-color": "text.primary",
        "transition": "transition.fast",
        "cursor": "pointer"
      }
    },

    "params-table": {
      "width": "100%",
      "font-size": "sm",
      "border-collapse": "collapse",
      "th": {
        "text-align": "left",
        "padding": "spacing.2 spacing.3",
        "color": "text.muted",
        "font-weight": "medium",
        "font-size": "xs",
        "text-transform": "uppercase",
        "letter-spacing": "0.05em",
        "border-bottom": "border.default"
      },
      "td": {
        "padding": "spacing.3",
        "border-bottom": "border.subtle",
        "vertical-align": "top"
      },
      "required-badge": {
        "font-size": "xs",
        "color": "semantic.error",
        "font-weight": "medium"
      }
    },

    "status-badge": {
      "font-size": "xs",
      "font-weight": "semibold",
      "padding": "spacing.1 spacing.2",
      "radius": "radius.sm",
      "2xx": {"bg": "#dcfce7", "color": "#166534"},
      "4xx": {"bg": "#fef9c3", "color": "#854d0e"},
      "5xx": {"bg": "#fee2e2", "color": "#991b1b"}
    },

    "search": {
      "input": {
        "height": "40px",
        "padding": "spacing.2 spacing.4",
        "radius": "radius.full",
        "border": "border.default",
        "bg": "surface.raised",
        "font-size": "sm",
        "focus-ring": "brand.primary",
        "placeholder-color": "text.muted"
      },
      "results": {
        "position": "absolute",
        "bg": "surface.page",
        "border": "border.default",
        "radius": "radius.lg",
        "shadow": "shadow.xl",
        "max-height": "400px",
        "overflow": "auto",
        "z-index": 200
      }
    },

    "button": {
      "primary": {
        "bg": "brand.primary",
        "color": "text.inverse",
        "hover-bg": "brand.primary-hover",
        "padding": "spacing.3 spacing.6",
        "radius": "radius.md",
        "font-weight": "medium",
        "font-size": "sm",
        "transition": "transition.fast"
      },
      "secondary": {
        "bg": "surface.raised",
        "color": "text.primary",
        "border": "border.default",
        "hover-bg": "surface.overlay",
        "padding": "spacing.3 spacing.6",
        "radius": "radius.md",
        "font-weight": "medium",
        "font-size": "sm",
        "transition": "transition.fast"
      },
      "ghost": {
        "bg": "transparent",
        "color": "text.secondary",
        "hover-bg": "surface.raised",
        "padding": "spacing.2 spacing.3",
        "radius": "radius.md",
        "font-size": "sm",
        "transition": "transition.fast"
      }
    },

    "alert": {
      "padding": "spacing.4",
      "radius": "radius.md",
      "border-left": "4px solid",
      "font-size": "sm",
      "info":    {"bg": "#eff6ff", "border": "#3b82f6", "color": "#1e40af"},
      "success": {"bg": "#f0fdf4", "border": "#10b981", "color": "#166534"},
      "warning": {"bg": "#fffbeb", "border": "#f59e0b", "color": "#92400e"},
      "error":   {"bg": "#fef2f2", "border": "#ef4444", "color": "#991b1b"}
    },

    "footer": {
      "bg": "surface.raised",
      "border-top": "border.default",
      "padding": "spacing.8 spacing.6",
      "font-size": "sm",
      "color": "text.muted"
    }
  },

  "pages": {
    "index": {
      "sections": ["hero", "stats-bar", "feature-cards", "quick-start", "links"]
    },
    "api-reference": {
      "layout": "sidebar + content",
      "sidebar": "tag navigation with endpoint list",
      "content": "endpoint blocks, collapsible, with params + body + responses + examples"
    },
    "examples": {
      "sections": ["auth", "multi-tenant", "error-handling", "2fa", "organizations"],
      "code-tabs": ["Python", "JavaScript", "cURL"]
    },
    "authentication": {
      "sections": ["jwt-flow", "2fa", "social", "magic-link", "webauthn", "best-practices"]
    }
  },

  "accessibility": {
    "color-contrast": "WCAG AA minimum (4.5:1 text, 3:1 UI)",
    "focus-visible": "2px solid brand.primary, offset 2px",
    "aria": {
      "nav": "role=navigation, aria-label",
      "main": "role=main",
      "search": "role=search, aria-label",
      "code-blocks": "aria-label with language",
      "buttons": "aria-label on icon-only buttons",
      "collapsible": "aria-expanded, aria-controls"
    },
    "keyboard": "full keyboard navigation, tab order logical",
    "motion": "prefers-reduced-motion respected",
    "lang": "lang=fr on html element"
  },

  "dry_rules": {
    "css_variables": "all design tokens as CSS custom properties in :root",
    "html_template": "single get_html_template() method, all pages use it",
    "component_methods": "one method per reusable HTML component (badge, code-block, table, card)",
    "no_inline_styles": "zero inline style attributes in generated HTML",
    "no_duplicate_strings": "all repeated strings extracted to constants or template methods",
    "asset_single_file": "one styles.css, one script.js — no duplication across pages"
  },

  "generation": {
    "charset": "UTF-8",
    "lang": "fr",
    "favicon": "data:image/svg+xml emoji ⚡",
    "google_fonts": ["Inter:wght@400;500;600;700", "JetBrains+Mono:wght@400;500"],
    "theme": "light with dark-mode via prefers-color-scheme",
    "dark_mode": {
      "surface.page":    "#0f172a",
      "surface.raised":  "#1e293b",
      "surface.overlay": "#334155",
      "text.primary":    "#f1f5f9",
      "text.secondary":  "#94a3b8",
      "border.default":  "#334155"
    }
  }
}
